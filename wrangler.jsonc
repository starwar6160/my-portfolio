{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-portfolio",
  "compatibility_date": "2026-04-08",
  "observability": {
    "enabled": true
  },
  "pages_build_output_dir": "./public",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "visitor_log",
      "database_id": "dec47004-d3c8-4cfa-b5e6-03b6c229ccae"
    }
  ]
}